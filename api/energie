// api/energie.js — Proxy Vercel minimal
//
// ODRÉ éCO2mix est appelé directement depuis le navigateur (CORS ouvert)
// Ce proxy ne gère que OilPriceAPI qui n'autorise pas les appels CORS directs.
//
// Variable d'environnement optionnelle sur Vercel :
//   OIL_PRICE_API_KEY → clé oilpriceapi.com (trial gratuit 7 jours)
//
// Sans clé : retourne null → le client utilise la valeur contextuelle (88$)

export default async function handler(req, res) {
  if (req.method !== 'GET') {
    return res.status(405).json({ error: 'Method not allowed' })
  }

  // CORS — autoriser les appels depuis le navigateur
  res.setHeader('Access-Control-Allow-Origin', '*')
  res.setHeader('Access-Control-Allow-Methods', 'GET')

  const result = {
    prix_baril_dollars: null,
    source_baril: 'non_configure',
    timestamp: new Date().toISOString(),
  }

  const OIL_KEY = process.env.OIL_PRICE_API_KEY
  if (OIL_KEY) {
    try {
      const oilRes = await fetch(
        'https://api.oilpriceapi.com/v1/prices/latest?by_code=BRENT_CRUDE_USD',
        {
          headers: { Authorization: `Token ${OIL_KEY}` },
          signal: AbortSignal.timeout(4000),
        }
      )
      if (oilRes.ok) {
        const data = await oilRes.json()
        if (data?.data?.price) {
          result.prix_baril_dollars = Math.round(data.data.price * 10) / 10
          result.source_baril = 'oilpriceapi'
        }
      }
    } catch (e) {
      console.warn('OilPriceAPI indisponible:', e.message)
      result.source_baril = 'erreur'
    }
  }

  // Fallback contextuel (Mars 2026, crise iranienne — Brent ~88$)
  if (result.prix_baril_dollars === null) {
    result.prix_baril_dollars = 88
    result.source_baril = 'fallback_contextuel'
  }

  res.setHeader('Cache-Control', 's-maxage=300') // cache Vercel 5 min
  return res.status(200).json(result)
}
