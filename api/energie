// api/energie.js — Proxy Vercel pour les données énergétiques réelles
// Variables d'environnement à configurer sur Vercel :
//   RTE_TOKEN        → token OAuth2 RTE (base64 de "client_id:client_secret")
//   OIL_PRICE_API_KEY → clé oilpriceapi.com (trial gratuit 7 jours)

export default async function handler(req, res) {
  if (req.method !== 'GET') {
    return res.status(405).json({ error: 'Method not allowed' })
  }

  // Résultat final — on remplit ce qu'on peut, fallback sur le reste
  const result = {
    source: {},
    prix_baril_dollars:          null,
    prix_gaz_mwh:                null,
    prix_electricite_marche_mwh: null,
    mix_energetique: {
      nucleaire_pct:    null,
      renouvelable_pct: null,
      gaz_pct:          null,
      charbon_pct:      null,
      autre_pct:        null,
    },
    echanges_frontaliers_mw: {
      uk: null, allemagne: null, suisse: null,
      italie: null, espagne: null, belgique: null,
      solde_total: null,
    },
    timestamp: new Date().toISOString(),
  }

  // ── 1. Prix du baril (oilpriceapi.com) ──────────────────────
  const OIL_KEY = process.env.OIL_PRICE_API_KEY
  if (OIL_KEY) {
    try {
      const oilRes = await fetch(
        'https://api.oilpriceapi.com/v1/prices/latest?by_code=BRENT_CRUDE_USD',
        { headers: { Authorization: `Token ${OIL_KEY}` }, signal: AbortSignal.timeout(4000) }
      )
      if (oilRes.ok) {
        const oilData = await oilRes.json()
        if (oilData?.data?.price) {
          result.prix_baril_dollars = Math.round(oilData.data.price * 10) / 10
          result.source.baril = 'oilpriceapi'
        }
      }
    } catch (e) {
      console.warn('oilpriceapi indisponible:', e.message)
    }
  }

  // ── 2. Données RTE (mix énergétique + échanges) ─────────────
  const RTE_TOKEN = process.env.RTE_TOKEN
  if (RTE_TOKEN) {
    try {
      // Obtenir un access token OAuth2 RTE
      const authRes = await fetch('https://digital.iservices.rte-france.com/token/oauth/', {
        method: 'POST',
        headers: {
          Authorization: `Basic ${RTE_TOKEN}`,
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'grant_type=client_credentials',
        signal: AbortSignal.timeout(4000),
      })

      if (authRes.ok) {
        const authData = await authRes.json()
        const accessToken = authData.access_token

        // Mix énergétique temps réel (éCO2mix)
        const [mixRes, echangesRes] = await Promise.allSettled([
          fetch(
            'https://digital.iservices.rte-france.com/open_api/actual_generation/v1/actual_generations_per_production_type',
            {
              headers: { Authorization: `Bearer ${accessToken}` },
              signal: AbortSignal.timeout(4000),
            }
          ),
          fetch(
            'https://digital.iservices.rte-france.com/open_api/physical_flow/v1/physical_flows',
            {
              headers: { Authorization: `Bearer ${accessToken}` },
              signal: AbortSignal.timeout(4000),
            }
          ),
        ])

        // Parser mix énergétique
        if (mixRes.status === 'fulfilled' && mixRes.value.ok) {
          const mixData = await mixRes.value.json()
          const productions = mixData?.actual_generations_per_production_type ?? []
          let total = 0
          const parType = {}
          productions.forEach(p => {
            const derniere = p.values?.at(-1)?.value ?? 0
            parType[p.production_type] = derniere
            total += derniere
          })
          if (total > 0) {
            const nucleaire = (parType['NUCLEAR'] ?? 0)
            const renouvelable = (parType['WIND_ONSHORE'] ?? 0) + (parType['WIND_OFFSHORE'] ?? 0)
              + (parType['SOLAR'] ?? 0) + (parType['HYDRO_RUN_OF_RIVER_AND_POUNDAGE'] ?? 0)
              + (parType['HYDRO_WATER_RESERVOIR'] ?? 0)
            const gaz = (parType['FOSSIL_GAS'] ?? 0)
            const charbon = (parType['FOSSIL_HARD_COAL'] ?? 0) + (parType['FOSSIL_BROWN_COAL_LIGNITE'] ?? 0)

            result.mix_energetique.nucleaire_pct    = Math.round((nucleaire / total) * 100)
            result.mix_energetique.renouvelable_pct = Math.round((renouvelable / total) * 100)
            result.mix_energetique.gaz_pct          = Math.round((gaz / total) * 100)
            result.mix_energetique.charbon_pct      = Math.round((charbon / total) * 100)
            result.mix_energetique.autre_pct        = Math.max(0, 100
              - result.mix_energetique.nucleaire_pct
              - result.mix_energetique.renouvelable_pct
              - result.mix_energetique.gaz_pct
              - result.mix_energetique.charbon_pct)
            result.source.mix = 'RTE_LIVE'
          }
        }

        // Parser échanges frontaliers
        if (echangesRes.status === 'fulfilled' && echangesRes.value.ok) {
          const echangesData = await echangesRes.value.json()
          const flows = echangesData?.physical_flows ?? []
          const MAP_PAYS = {
            'ENGLAND': 'uk', 'GERMANY': 'allemagne', 'SWITZERLAND': 'suisse',
            'ITALY': 'italie', 'SPAIN': 'espagne', 'BELGIUM': 'belgique',
          }
          let soldeTot = 0
          flows.forEach(f => {
            const pays = MAP_PAYS[f.receiver_country_name ?? f.sender_country_name]
            if (!pays) return
            const val = f.values?.at(-1)?.value ?? 0
            const sens = f.receiver_country_name === 'FRANCE' ? -val : val
            result.echanges_frontaliers_mw[pays] = (result.echanges_frontaliers_mw[pays] ?? 0) + sens
            soldeTot += sens
          })
          result.echanges_frontaliers_mw.solde_total = Math.round(soldeTot)
          result.source.echanges = 'RTE_LIVE'
        }
      }
    } catch (e) {
      console.warn('RTE API indisponible:', e.message)
    }
  }

  // ── 3. Fallbacks contextuels (Mars 2026, crise iranienne) ───
  // Ces valeurs reflètent la situation géopolitique actuelle :
  // baril Brent autour de 88-90$ (détroit d'Ormuz sous tension)
  if (result.prix_baril_dollars === null) {
    result.prix_baril_dollars = 88
    result.source.baril = 'fallback_contextuel'
  }
  if (result.prix_gaz_mwh === null) {
    result.prix_gaz_mwh = 42
    result.source.gaz = 'fallback_contextuel'
  }
  if (result.prix_electricite_marche_mwh === null) {
    result.prix_electricite_marche_mwh = 95
    result.source.electricite = 'fallback_contextuel'
  }
  if (result.mix_energetique.nucleaire_pct === null) {
    result.mix_energetique = { nucleaire_pct: 68, renouvelable_pct: 22, gaz_pct: 6, charbon_pct: 1, autre_pct: 3 }
    result.source.mix = 'fallback_contextuel'
  }
  if (result.echanges_frontaliers_mw.solde_total === null) {
    result.echanges_frontaliers_mw = {
      uk: 1200, allemagne: -400, suisse: 1800, italie: 900, espagne: 400, belgique: 100, solde_total: 4000
    }
    result.source.echanges = 'fallback_contextuel'
  }

  res.setHeader('Cache-Control', 's-maxage=300') // cache 5 min côté Vercel
  return res.status(200).json(result)
}
